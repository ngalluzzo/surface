{
	"name": "schemarr",
	"version": "1.0.0",
	"type": "module",
	"exports": {
		".": {
			"types": "./src/index.ts",
			"bun": "./src/index.ts",
			"default": "./dist/index.js"
		}
	},
	"bin": {
		"schemarr": "./bin/schemarr"
	},
	"files": [
		"dist",
		"bin",
		"src"
	],
	"scripts": {
		"typecheck": "tsc --noEmit",
		"test": "bun test",
		"test:coverage": "bun test --coverage",
		"lint": "eslint src",
		"lint:fix": "eslint src --fix",
		"format": "prettier --write src",
		"format:fix": "prettier --write src --fix",
		"build": "bun clean && bun build:pkg && bun build:bin",
		"build:pkg": "bun build ./src/index.ts --outdir ./dist --external zod",
		"build:bin": "bun build --compile ./src/cli/index.ts --outfile ./bin/schemarr",
		"clean": "rm -rf ./bin ./dist"
	},
	"devDependencies": {
		"@eslint/compat": "^2.0.2",
		"@eslint/js": "^9.39.2",
		"@types/bun": "latest",
		"@types/json-schema": "^7.0.15",
		"@types/pluralize": "^0.0.33",
		"bun-types": "^1.3.8",
		"eslint": "^9.39.2",
		"eslint-plugin-functional": "^9.0.2",
		"graphql": "^16.0.0",
		"prettier": "^3.8.1",
		"typescript-eslint": "^8.54.0"
	},
	"peerDependencies": {
		"graphql": ">=16.0.0",
		"zod": "^4.3.6",
		"typescript": "^5.9.3"
	},
	"dependencies": {
		"chalk": "^5.6.2",
		"commander": "^14.0.3",
		"figlet": "^1.10.0",
		"inquirer": "^13.2.2",
		"pluralize": "^8.0.0"
	}
}
