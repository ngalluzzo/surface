{
	"$schema": "http://json-schema.org/draft-07/schema#",
	"title": "Post",
	"type": "object",
	"required": ["id", "title", "author"],
	"properties": {
		"id": {
			"type": "string",
			"format": "uuid"
		},
		"title": {
			"type": "string",
			"maxLength": 500
		},
		"body": {
			"type": "string"
		},
		"author": {
			"$ref": "#/definitions/Author"
		},
		"reviewer": {
			"$ref": "#/definitions/Author"
		},
		"published_at": {
			"type": "string",
			"format": "date-time"
		}
	},
	"definitions": {
		"Author": {
			"title": "Author",
			"type": "object",
			"required": ["id", "username"],
			"properties": {
				"id": {
					"type": "string",
					"format": "uuid"
				},
				"username": {
					"type": "string",
					"maxLength": 100
				},
				"email": {
					"type": "string",
					"format": "email"
				}
			}
		}
	}
}
