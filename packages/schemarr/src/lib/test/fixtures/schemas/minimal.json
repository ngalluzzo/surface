{
	"$schema": "http://json-schema.org/draft-07/schema#",
	"title": "User",
	"type": "object",
	"required": ["id", "email"],
	"properties": {
		"id": {
			"type": "string",
			"format": "uuid"
		},
		"email": {
			"type": "string",
			"format": "email",
			"maxLength": 255
		},
		"name": {
			"type": "string"
		}
	}
}
