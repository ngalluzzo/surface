{
	"$schema": "http://json-schema.org/draft-07/schema#",
	"title": "Order",
	"type": "object",
	"required": ["id", "customer", "status", "line_items"],
	"properties": {
		"id": {
			"type": "string",
			"format": "uuid"
		},
		"order_number": {
			"type": "string",
			"maxLength": 20,
			"pattern": "^ORD-[0-9]+$"
		},
		"customer": {
			"$ref": "#/definitions/Customer"
		},
		"status": {
			"type": "string",
			"enum": ["pending", "confirmed", "shipped", "delivered", "cancelled"]
		},
		"line_items": {
			"type": "array",
			"items": {
				"$ref": "#/definitions/LineItem"
			}
		},
		"shipping_address": {
			"type": "object",
			"properties": {
				"street": { "type": "string" },
				"city": { "type": "string" },
				"state": { "type": "string", "maxLength": 2 },
				"zip": { "type": "string" },
				"country": { "type": "string", "maxLength": 2 }
			}
		},
		"notes": {
			"type": "string"
		},
		"total_cents": {
			"type": "integer",
			"minimum": 0
		},
		"placed_at": {
			"type": "string",
			"format": "date-time"
		},
		"updated_at": {
			"type": "string",
			"format": "date-time"
		}
	},
	"x-unique": ["order_number"],
	"definitions": {
		"Customer": {
			"title": "Customer",
			"type": "object",
			"required": ["id", "email"],
			"properties": {
				"id": {
					"type": "string",
					"format": "uuid"
				},
				"email": {
					"type": "string",
					"format": "email",
					"maxLength": 255
				},
				"full_name": {
					"type": "string",
					"maxLength": 200
				},
				"phone": {
					"type": "string",
					"maxLength": 20
				},
				"created_at": {
					"type": "string",
					"format": "date-time"
				}
			},
			"x-unique": ["email"]
		},
		"LineItem": {
			"title": "LineItem",
			"type": "object",
			"required": ["id", "product_name", "quantity", "unit_price_cents"],
			"properties": {
				"id": {
					"type": "string",
					"format": "uuid"
				},
				"product_name": {
					"type": "string",
					"maxLength": 200
				},
				"sku": {
					"type": "string",
					"maxLength": 50
				},
				"quantity": {
					"type": "integer",
					"minimum": 1
				},
				"unit_price_cents": {
					"type": "integer",
					"minimum": 0
				}
			}
		}
	}
}
